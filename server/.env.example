# ==========================================
# CONFIGURACION DEL SERVIDOR
# ==========================================
PORT=5000
NODE_ENV=development

# ==========================================
# BASE DE DATOS (MySQL/MariaDB)
# ==========================================
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=shortvideo

# ==========================================
# JWT (Autenticacion)
# ==========================================
JWT_SECRET=your_jwt_secret_key_here

# ==========================================
# ALIBABA CLOUD OSS (Almacenamiento de Media)
# ==========================================
OSS_REGION=oss-us-west-1
OSS_ENDPOINT=https://oss-us-west-1.aliyuncs.com
OSS_ACCESS_KEY_ID=your_access_key_id
OSS_ACCESS_KEY_SECRET=your_access_key_secret
OSS_BUCKET=your_bucket_name

# ==========================================
# CDN (Content Delivery Network)
# ==========================================
# Dominio del CDN de Alibaba Cloud para servir videos y thumbnails
CDN_DOMAIN=https://media.hurammy.com

# ==========================================
# AI SERVICES (Opcional)
# ==========================================
OPENAI_API_KEY=your_openai_api_key
